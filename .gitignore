# Raw fuzzer output — millions of state-test JSONs. Reproducible from a re-run,
# not useful without goevmlab replay, and too big for git (4.6 GB / 990k files
# for a single 13h baseline phase). Keep locally, don't push.
out/baseline/
out/baseline.4t/
out/baseline.stuck/
out/baseline.pre-16h/
out/llm_guided/
out.zip

# Session state files — regenerated on every supervisor launch.
out/*.pid
out/*.start
out/*.stop
out/*.log.prev

# Local Claude Code session-resume shortcut (user-specific).
claude.claude

# Python bytecode.
__pycache__/
*.pyc

# Local llama-server session state (started by scripts/start_llama_server.sh).
out/llama_server.pid
out/llama_server.log

# RAG corpus + FAISS index — regenerable from build_index.py + a shallow
# clone of ethereum/EIPs. EIPs alone is 153 MB; index is small but depends
# on the embedding model version, so we don't pin it.
orchestrator/rag/corpus/EIPs/
orchestrator/rag/index/

# Day-4 differential-harness build artifacts.
goevmlab/runtest
.fuzzcounter
